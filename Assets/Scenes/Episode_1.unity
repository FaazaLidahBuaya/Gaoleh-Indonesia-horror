--- !u!114 &917391392
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 917391386}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ab2975096cef4ca458f07ed87d71e8a0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::StoryMessageManager
  pesanMalam1:
  - namaPengirim: Pembeli
    isiPesan: 'Halo arya, katanya kamu ingin menjual rumah ya? saya bisa bantu buat
      mengurus beberapa hal... '
    waktuTungguSebelumDikirim: 10
  - namaPengirim: Pembeli
    isiPesan: 'Untuk dokumennya sendiri harus ada:

      1. Sertifikat hak milik

      2.
      KK

      3. Dokumen wajib pajak'
    waktuTungguSebelumDikirim: 12
  - namaPengirim: Rumah sakit
    isiPesan: Halo pak, untuk tagihan perawatan rumah sakit harus segera dibayarkan
      paling lama 3 hari ya... jika lebih, pihak rumah sakit tidak bisa menerima
      pasien lagi...
    waktuTungguSebelumDikirim: 23
  pesanMalam2:
  - namaPengirim: Pembeli
    isiPesan: Halo lagi Arya, kamu sudah mengumpulkan semua dokumennya? kalau iya
      sekalian dong, bersihin rumahnya. saya mah bakal kasih bonus kalo rumahnya
      bersih...
    waktuTungguSebelumDikirim: 8
  pesanMalam3:
  - namaPengirim: Istrikuu
    isiPesan: Halo sayang? entah kenapa peraasaan ku sedang tidak enak... kamu baik
      baik sajakan disana? semoga iya, aku merindukanmu disini.
    waktuTungguSebelumDikirim: 15
  - namaPengirim: Info desa
    isiPesan: Mohon maaf karena desa sedang mengalami pemadaman listrik untuk sementara
      waktu dan akan berfungsi kembali besok pagi
    waktuTungguSebelumDikirim: 5
